# ============================================================
# .NET (api/ and worker/)
# ============================================================
bin/
obj/
.vs/
*.user
.idea/

# NuGet packages (restored by dotnet restore inside Docker)
packages/
*.nupkg

# Local publish output
publish/
**/publish/

# Local databases
*.db
*.db-shm
*.db-wal

# ============================================================
# Angular (frontend/)
# ============================================================

# Never commit - restored by npm install inside Docker
frontend/node_modules/

# Never commit - generated by ng build inside Docker
frontend/dist/

# Angular CLI cache
frontend/.angular/
.angular/

# ============================================================
# Docker
# ============================================================
.docker/

# ============================================================
# OS
# ============================================================

# macOS
.DS_Store
._*

# Windows
Thumbs.db
Desktop.ini

# ============================================================
# Logs
# ============================================================
*.log
logs/
log/

# ============================================================
# IDE
# ============================================================

# JetBrains Rider
.idea/

# VS Code (keep launch/tasks/settings if your team shares them)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ============================================================
# Misc
# ============================================================
*.bak
*.tmp
tmp/
temp/